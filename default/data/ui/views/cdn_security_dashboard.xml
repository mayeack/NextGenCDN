<dashboard version="1.1">
  <label>CDN Security Dashboard</label>
  <description>Detect and investigate malicious traffic patterns: bot activity, DDoS, credential stuffing, and anomalous request rates.</description>

  <fieldset submitButton="false">
    <input type="time" token="time_range" searchWhenChanged="true">
      <label>Time Range</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="severity_filter" searchWhenChanged="true">
      <label>Severity</label>
      <choice value="*">All</choice>
      <choice value="critical">Critical</choice>
      <choice value="high">High</choice>
      <choice value="medium">Medium</choice>
      <choice value="low">Low</choice>
      <default>*</default>
    </input>
  </fieldset>

  <!-- Row 1: KPI Summary -->
  <row>
    <panel>
      <title>Total Security Events</title>
      <single>
        <search>
          <query>index=cdn sourcetype=cdn:security:events severity=$severity_filter$
| stats count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="numberPrecision">0</option>
        <option name="rangeColors">["0x53a051","0xf8be34","0xdc4e41"]</option>
        <option name="rangeValues">[500,2000]</option>
        <option name="underLabel">Events</option>
        <option name="useColors">1</option>
      </single>
    </panel>
    <panel>
      <title>Unique Attacker IPs</title>
      <single>
        <search>
          <query>index=cdn sourcetype=cdn:security:events severity=$severity_filter$
| stats dc(source_ip) as unique_ips</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="numberPrecision">0</option>
        <option name="underLabel">Unique IPs</option>
        <option name="useColors">0</option>
      </single>
    </panel>
    <panel>
      <title>Critical / High Events</title>
      <single>
        <search>
          <query>index=cdn sourcetype=cdn:security:events (severity="critical" OR severity="high")
| stats count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="numberPrecision">0</option>
        <option name="rangeColors">["0x53a051","0xf8be34","0xdc4e41"]</option>
        <option name="rangeValues">[100,500]</option>
        <option name="underLabel">Critical + High</option>
        <option name="useColors">1</option>
      </single>
    </panel>
    <panel>
      <title>Peak Request Rate</title>
      <single>
        <search>
          <query>index=cdn sourcetype=cdn:security:events severity=$severity_filter$
| stats max(request_rate) as peak_rate</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="field">peak_rate</option>
        <option name="numberPrecision">0</option>
        <option name="underLabel">req/s</option>
        <option name="useColors">0</option>
      </single>
    </panel>
  </row>

  <!-- Row 2: Attack Distribution -->
  <row>
    <panel>
      <title>Top Attack Types</title>
      <chart>
        <search>
          <query>index=cdn sourcetype=cdn:security:events severity=$severity_filter$
| stats count by attack_type
| sort -count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">right</option>
      </chart>
    </panel>
    <panel>
      <title>Top 15 Source IPs by Event Count</title>
      <chart>
        <search>
          <query>index=cdn sourcetype=cdn:security:events severity=$severity_filter$
| stats count avg(request_rate) as avg_rate by source_ip
| sort -count
| head 15
| eval avg_rate=round(avg_rate, 0)</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.axisTitleX.text">Events</option>
        <option name="charting.axisTitleY.text">Source IP</option>
      </chart>
    </panel>
  </row>

  <!-- Row 3: Timeline and Regional -->
  <row>
    <panel>
      <title>Attack Events Over Time by Type</title>
      <chart>
        <search>
          <query>index=cdn sourcetype=cdn:security:events severity=$severity_filter$
| timechart span=30m count by attack_type</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">area</option>
        <option name="charting.chart.stackMode">stacked</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Events</option>
      </chart>
    </panel>
    <panel>
      <title>Targeted POPs</title>
      <chart>
        <search>
          <query>index=cdn sourcetype=cdn:security:events severity=$severity_filter$
| stats count by target_pop
| sort -count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.axisTitleX.text">Events</option>
        <option name="charting.axisTitleY.text">Target POP</option>
      </chart>
    </panel>
  </row>

  <!-- Row 4: DDoS Focus -->
  <row>
    <panel>
      <title>DDoS Request Rate Over Time</title>
      <chart>
        <search>
          <query>index=cdn sourcetype=cdn:security:events attack_type="ddos"
| timechart span=15m avg(request_rate) as avg_rate max(request_rate) as peak_rate</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">area</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Request Rate</option>
      </chart>
    </panel>
    <panel>
      <title>Mitigation Actions</title>
      <chart>
        <search>
          <query>index=cdn sourcetype=cdn:security:events severity=$severity_filter$
| stats count by mitigation_action
| sort -count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">right</option>
      </chart>
    </panel>
  </row>

  <!-- Row 5: Severity and Detail -->
  <row>
    <panel>
      <title>Severity Distribution Over Time</title>
      <chart>
        <search>
          <query>index=cdn sourcetype=cdn:security:events
| timechart span=30m count by severity</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.chart.stackMode">stacked</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Events</option>
      </chart>
    </panel>
    <panel>
      <title>Recent Critical Events</title>
      <table>
        <search>
          <query>index=cdn sourcetype=cdn:security:events severity="critical"
| table _time attack_type source_ip target_pop request_rate mitigation_action
| sort -_time
| head 20</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="count">10</option>
      </table>
    </panel>
  </row>
</dashboard>
